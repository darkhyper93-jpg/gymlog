generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // url: la connection string con pooler (pgbouncer, puerto 6543) que usa la app en runtime.
  // directUrl: la conexión directa (puerto 5432) que Prisma usa para migraciones / db push.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Exercise {
  id          String   @id @default(cuid())
  name        String
  target      String?
  // Grupo muscular para organizar los ejercicios en secciones (espalda, pecho, etc.).
  // String? (no enum) porque SQLite no soporta enums en Prisma; se valida en el backend.
  // Nullable para no romper los ejercicios ya cargados antes de sumar este campo.
  muscleGroup String?
  // Dueño del ejercicio: cada usuario ve y maneja SOLO los suyos. Las series cuelgan del
  // ejercicio, así que quedan separadas por usuario de forma transitiva.
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime @default(now())
  sets        WorkoutSet[]
}

// Usuario para el login. Para V1 (un solo usuario) no se vincula a Exercise/WorkoutSet:
// el login solo protege las rutas, no separa datos por usuario.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  exercises    Exercise[]
}

model WorkoutSet {
  id         String   @id @default(cuid())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  date       DateTime @default(now())
  weight     Float
  reps       Int
  rir        Int?
  createdAt  DateTime @default(now())
}