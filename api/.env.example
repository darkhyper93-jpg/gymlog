# Copiá este archivo a .env y completá los valores. (.env NO se sube al repo.)

# Base de datos.
#  - Dev local: SQLite, un archivo. Schema con provider = "sqlite".
#      DATABASE_URL="file:./dev.db"
#  - Producción: Postgres (Supabase). Cambiar el provider del schema a "postgresql" y pegar la
#    connection string de Supabase (Project Settings → Database → Connection string → URI).
#      DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DATABASE_URL="file:./dev.db"

# Secreto para firmar los JWT. En producción es OBLIGATORIO y debe ser largo y aleatorio
# (ej. `openssl rand -base64 32`). NO reutilizar el de dev.
JWT_SECRET="dev-gymlog-secret-cambialo-en-produccion"

# Origen(es) permitido(s) por CORS. Vacío en dev (permite todo). En producción, la URL del
# frontend (uno o varios separados por coma), ej. https://gymlog-web.onrender.com
# CORS_ORIGIN="https://gymlog-web.onrender.com"

# Puerto. En local default 4000; en Render lo inyecta la plataforma (no hace falta setearlo).
# PORT=4000

# Google Gemini (parseo de rutinas importadas). Obtené la key en https://aistudio.google.com/apikey
# Sin esta key, /import/parse devuelve 503. NUNCA va en el frontend.
# GEMINI_API_KEY=""
# Modelo opcional; default gemini-2.5-flash.
# GEMINI_MODEL="gemini-2.5-flash"
